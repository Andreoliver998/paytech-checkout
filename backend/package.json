    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}
