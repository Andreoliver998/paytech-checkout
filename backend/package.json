{
  "name": "paytech-checkout",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "prisma": "node scripts/prisma-with-root-env.js",
    "prisma:generate": "npm run prisma -- generate --schema ../database/schema.prisma",
